# ── Django ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me
# MUST be False in production. With DEBUG=False run `manage.py collectstatic`
# before serving — whitenoise reads the hashed static manifest.
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
# Absolute base URL of this deployment — used in WhatsApp/email links.
# Use https:// in production to switch on the HTTPS security hardening.
SITE_URL=http://127.0.0.1:8000

# ── Security (only consulted when DEBUG=False) ───────────────────────────────
# Logger verbosity: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO
# These take effect only when SITE_URL is https:// (TLS terminates in front of Django):
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DB_NAME=atlashub
DB_USER=atlashub
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5432
# Seconds to keep a DB connection open for reuse (0 in DEBUG, 60 in prod by default).
# DB_CONN_MAX_AGE=60

# ── Email (password-reset fallback; console backend used when unset) ─────────
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=postmaster@example.com
# EMAIL_HOST_PASSWORD=change-me
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=AtlasHub <noreply@example.com>

# ── Error tracking (Sentry) ──────────────────────────────────────────────────
# Leave SENTRY_DSN unset to disable Sentry entirely (dev/CI default).
# SENTRY_DSN=https://<key>@<org>.ingest.de.sentry.io/<project>
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# Fraction of transactions traced for performance monitoring (0.0–1.0).
# SENTRY_TRACES_SAMPLE_RATE=0.0
# Attach request headers + logged-in user to events (True/False).
# SENTRY_SEND_DEFAULT_PII=True

# ── WhatsApp (shared worker) ─────────────────────────────────────────────────
# AtlasHub does NOT run its own worker. It uses the single whatsapp-node-worker
# that runs under ClockInSop (pm2) on the same host — one WhatsApp number for all
# apps. Point these at it and use the SAME token the worker is started with.
# The worker binds 127.0.0.1, so every app sharing it must be on the same server.
WHATSAPP_WORKER_URL=http://127.0.0.1:8025
WHATSAPP_WORKER_TOKEN=shared-worker-token-change-me
# Default dialling code for normalising local numbers (27 = South Africa).
COUNTRY_CODE=27
